# ============================================================
# 🐝 HoneyComb 蜜探 — Environment Configuration
# ============================================================

# --- AI Engine ---
# 支持任何 OpenAI 兼容接口：DeepSeek, Ollama, vLLM, Together AI, OpenRouter...
NEXT_PUBLIC_HERMES_BASE_URL=https://api.deepseek.com/v1
NEXT_PUBLIC_HERMES_API_KEY=your-api-key-here

# 蜂后模型 — 规划、决策、对话、报告生成（需要强推理能力）
NEXT_PUBLIC_QUEEN_MODEL=deepseek-v4-pro

# 蜜蜂模型 — 搜索结果分析、知识图谱构建（快速+低成本）
NEXT_PUBLIC_BEE_MODEL=deepseek-v4-flash

# --- 花田信息源 API Keys ---
# (也可以在花田面板中直接配置)

# Google Search (via Serper.dev)
# SERPER_API_KEY=

# Twitter/X
# TWITTER_BEARER_TOKEN=

# GitHub (可选, 提高 rate limit)
# GITHUB_TOKEN=

# Google Scholar (via SerpAPI)
# SERPAPI_KEY=

# Jina (Web Crawler, 可选)
# JINA_API_KEY=
